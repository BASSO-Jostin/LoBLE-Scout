&pinctrl {
 uart0_default: uart0_default {
  group1 {
   pinmux = <(39 << 4 | 0 << 0)>;
  };
  group2 {
   pinmux = <(40 << 4 | 0 << 0)>;
   input-enable;
  };
 };
 i2c0_default: i2c0_default {
  group1 {
   pinmux = <(5 << 4 | 0 << 0)>, <(6 << 4 | 0 << 0)>;
   drive-open-drain;
   drive-strength = "0.5";
   bias-pull-up;
  };
 };
 i2c1_default: i2c1_default {
  group1 {
   pinmux = <(8 << 4 | 0 << 0)>, <(9 << 4 | 0 << 0)>;
   drive-open-drain;
   drive-strength = "0.5";
   bias-pull-up;
  };
 };
 i2c2_default: i2c2_default {
  group1 {
   pinmux = <(27 << 4 | 4 << 0)>, <(25 << 4 | 4 << 0)>;
   drive-open-drain;
   drive-strength = "0.5";
   bias-pull-up;
  };
 };
 i2c3_default: i2c3_default {
  group1 {
   pinmux = <(42 << 4 | 4 << 0)>, <(43 << 4 | 4 << 0)>;
   drive-open-drain;
   drive-strength = "0.5";
   bias-pull-up;
  };
 };
 i2c4_default: i2c4_default {
  group1 {
   pinmux = <(39 << 4 | 4 << 0)>, <(40 << 4 | 4 << 0)>;
   drive-open-drain;
   drive-strength = "0.5";
   bias-pull-up;
  };
 };
 i2c5_default: i2c5_default {
  group1 {
   pinmux = <(48 << 4 | 4 << 0)>, <(49 << 4 | 4 << 0)>;
   drive-open-drain;
   drive-strength = "0.5";
   bias-pull-up;
  };
 };

 spi0_default: spi0_default {
  group1 {
   pinmux = <(5 << 4 | 1 << 0)>, <(6 << 4 | 1 << 0)>, <(7 << 4 | 1 << 0)>;
  };
  group2 {
   pinmux = <(1 << 4 | 7 << 0)>;
   drive-push-pull;
   ambiq,iom-nce-module = <0>;
   ambiq,iom-num = <0>;
  };
 };
 spi1_default: spi1_default {
  group1 {
   pinmux = <(8 << 4 | 1 << 0)>, <(9 << 4 | 1 << 0)>, <(10 << 4 | 1 << 0)>;
  };
  group2 {
   pinmux = <(11 << 4 | 1 << 0)>;
   drive-push-pull;

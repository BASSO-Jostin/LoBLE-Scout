&uart0 {
 status = "okay";
 current-speed = <9600>;
 pinctrl-0 = <&uart0_default>;
 pinctrl-names = "default";
};

&uart1 {
 status = "okay";
 current-speed = <115200>;
 pinctrl-0 = <&uart1_default>;
 pinctrl-names = "default";
};

&pinctrl {
    uart1_default: uart1_default {
        group1 {
            pinmux = <(42 << 4 | 0 << 0)>;
        };
        group2 {
            pinmux = <(43 << 4 | 0 << 0)>;
            input-enable;
        };
    };
};
